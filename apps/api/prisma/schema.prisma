generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS =======================

enum BedStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
  BLOCKED
}

enum CleaningStatus {
  PENDING
  READY
  UNASSIGNED
  IN_PROGRESS
  PAUSED
  DONE
  VERIFIED
  CANCELLED
}

enum HousekeepingRole {
  HOUSEKEEPER
  SUPERVISOR
  RECEPTIONIST
}

enum RoomCategory {
  PRIVATE
  SHARED
}

enum TaskType {
  CLEANING
  SANITIZATION
  MAINTENANCE
  PREPARATION
}

enum Capability {
  CLEANING
  SANITIZATION
  MAINTENANCE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskLogEvent {
  CREATED
  ASSIGNED
  READY
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  VERIFIED
  CANCELLED
  REOPENED
  NOTE_ADDED
}

enum CheckoutSource {
  CLOUDBEDS
  MANUAL
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  FURNITURE
  PEST
  OTHER
}

enum DiscrepancyType {
  BED_STATUS_MISMATCH
  GUEST_EXTENSION
  UNEXPECTED_OCCUPANCY
  OTHER
}

enum DiscrepancyStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

// ── PMS Core enums ──

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CHECKING_OUT
  CLEANING
  INSPECTION
  MAINTENANCE
  OUT_OF_SERVICE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  CREDIT
  OVERDUE
}

// ── New enums for multi-tenant foundation ──

enum OrgPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SystemRole {
  OWNER
  MANAGER
  RECEPTIONIST
  HOUSEKEEPER
  TECHNICIAN
  AUDITOR
}

enum PropertyType {
  HOTEL
  HOSTAL
  BOUTIQUE
  GLAMPING
  ECO_LODGE
  VACATION_RENTAL
}

// ======================= MULTI-TENANT FOUNDATION =======================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(STARTER)
  countryCode String   @default("MX") @map("country_code")
  timezone    String   @default("America/Cancun")
  currency    String   @default("MXN")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Reverse relations (denormalized organizationId in all business tables)
  properties        Property[]
  users             User[]
  rooms             Room[]
  beds              Bed[]
  housekeepingStaff HousekeepingStaff[]
  checkouts         Checkout[]
  cleaningTasks     CleaningTask[]
  taskLogs          TaskLog[]
  cleaningNotes     CleaningNote[]
  maintenanceIssues MaintenanceIssue[]
  bedDiscrepancies  BedDiscrepancy[]
  pushTokens        PushToken[]
  pmsConfigs        PmsConfig[]
  propertySettings  PropertySettings[]
  roomTypes         RoomType[]
  roomStatusLogs    RoomStatusLog[]
  guestStays        GuestStay[]
  roomTypeChecklists RoomTypeChecklist[]
  roomReadinessTasks RoomReadinessTask[]
  stayJourneys       StayJourney[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id])
  propertyRoles UserPropertyRole[]
  staffProfiles HousekeepingStaff[]

  @@index([organizationId])
  @@map("users")
}

model UserPropertyRole {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  propertyId String     @map("property_id")
  role       SystemRole
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId, role])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_roles")
}

// ======================= CORE MODELS =======================

model Property {
  id             String        @id @default(uuid())
  organizationId String?       @map("organization_id")
  name           String
  type           PropertyType  @default(HOTEL)
  taxId          String?       @map("tax_id")
  checkinTime    String        @default("15:00") @map("checkin_time")
  checkoutTime   String        @default("12:00") @map("checkout_time")
  isActive       Boolean       @default(true) @map("is_active")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  rooms        Room[]
  roomTypes    RoomType[]
  staff        HousekeepingStaff[]
  pmsConfig    PmsConfig?
  settings     PropertySettings?
  userRoles    UserPropertyRole[]
  stayJourneys StayJourney[]

  @@index([organizationId])
  @@map("properties")
}

model Room {
  id              String      @id @default(uuid())
  organizationId  String?     @map("organization_id")
  propertyId      String
  number          String
  floor           Int?
  category        RoomCategory
  capacity        Int
  status          RoomStatus  @default(AVAILABLE) @map("room_status")
  roomTypeId      String?     @map("room_type_id")
  cloudbedsRoomId String?
  notes           String?
  deletedAt       DateTime?   @map("deleted_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization?  @relation(fields: [organizationId], references: [id])
  property     Property       @relation(fields: [propertyId], references: [id])
  roomType     RoomType?       @relation(fields: [roomTypeId], references: [id])
  beds         Bed[]
  checkouts    Checkout[]
  statusLogs   RoomStatusLog[]
  guestStays   GuestStay[]
  readinessTasks RoomReadinessTask[]
  staySegments StaySegment[]

  @@unique([propertyId, number])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([status])
  @@map("rooms")
}

model Bed {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  label          String
  roomId         String
  status         BedStatus @default(AVAILABLE)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization?    @relation(fields: [organizationId], references: [id])
  room          Room             @relation(fields: [roomId], references: [id])
  cleaningTasks CleaningTask[]
  discrepancies BedDiscrepancy[]

  @@index([organizationId])
  @@map("beds")
}

model HousekeepingStaff {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  userId         String?          @map("user_id")
  propertyId     String
  name           String
  email          String           @unique
  passwordHash   String
  role           HousekeepingRole
  active         Boolean          @default(true)
  capabilities   Capability[]
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now())

  organization  Organization?   @relation(fields: [organizationId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  tasks         CleaningTask[]  @relation("AssignedTasks")
  verifiedTasks CleaningTask[]  @relation("VerifiedTasks")
  taskLogs      TaskLog[]
  cleaningNotes         CleaningNote[]
  pushTokens            PushToken[]
  checkouts             Checkout[]       @relation("ManualCheckouts")
  issues                MaintenanceIssue[]
  reportedDiscrepancies BedDiscrepancy[] @relation("DiscrepancyReporter")
  resolvedDiscrepancies BedDiscrepancy[] @relation("DiscrepancyResolver")

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("housekeeping_staff")
}

model Checkout {
  id                     String         @id @default(uuid())
  organizationId         String?        @map("organization_id")
  roomId                 String
  guestName              String?
  actualCheckoutAt       DateTime
  source                 CheckoutSource
  cloudbedsReservationId String?        @unique
  isEarlyCheckout        Boolean        @default(false)
  hasSameDayCheckIn      Boolean        @default(false)
  notes                  String?
  enteredById            String?
  cancelled              Boolean        @default(false)
  cancelledAt            DateTime?
  createdById            String?        @map("created_by_id")
  createdAt              DateTime       @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  room         Room              @relation(fields: [roomId], references: [id])
  enteredBy    HousekeepingStaff? @relation("ManualCheckouts", fields: [enteredById], references: [id])
  tasks        CleaningTask[]

  @@index([organizationId])
  @@map("checkouts")
}

model CleaningTask {
  id                 String         @id @default(uuid())
  organizationId     String?        @map("organization_id")
  bedId              String
  checkoutId         String?
  assignedToId       String?
  status             CleaningStatus @default(PENDING)
  taskType           TaskType       @default(CLEANING)
  requiredCapability Capability     @default(CLEANING)
  priority           Priority       @default(MEDIUM)
  hasSameDayCheckIn  Boolean        @default(false)
  startedAt          DateTime?
  finishedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  createdById        String?        @map("created_by_id")
  updatedById        String?        @map("updated_by_id")
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization Organization?      @relation(fields: [organizationId], references: [id])
  bed          Bed                @relation(fields: [bedId], references: [id])
  checkout     Checkout?          @relation(fields: [checkoutId], references: [id])
  assignedTo   HousekeepingStaff? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  verifiedBy   HousekeepingStaff? @relation("VerifiedTasks", fields: [verifiedById], references: [id])
  logs         TaskLog[]
  notes        CleaningNote[]
  issues       MaintenanceIssue[]

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId, status])
  @@index([bedId])
  @@index([checkoutId])
  @@map("cleaning_tasks")
}

model TaskLog {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  taskId         String
  staffId        String?
  event          TaskLogEvent
  note           String?
  createdAt      DateTime     @default(now())

  organization Organization?      @relation(fields: [organizationId], references: [id])
  task         CleaningTask       @relation(fields: [taskId], references: [id])
  staff        HousekeepingStaff? @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@index([taskId])
  @@map("task_logs")
}

model CleaningNote {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  taskId         String
  staffId        String
  content        String
  createdAt      DateTime @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  task         CleaningTask      @relation(fields: [taskId], references: [id])
  staff        HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("cleaning_notes")
}

model MaintenanceIssue {
  id             String              @id @default(uuid())
  organizationId String?             @map("organization_id")
  taskId         String
  reportedById   String
  category       MaintenanceCategory
  description    String
  photoUrl       String?
  resolved       Boolean             @default(false)
  createdById    String?             @map("created_by_id")
  createdAt      DateTime            @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  task         CleaningTask      @relation(fields: [taskId], references: [id])
  reportedBy   HousekeepingStaff @relation(fields: [reportedById], references: [id])

  @@index([organizationId])
  @@map("maintenance_issues")
}

model PushToken {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  staffId        String
  token          String   @unique
  platform       String
  active         Boolean  @default(true)
  lastSeenAt     DateTime @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  staff        HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("push_tokens")
}

model PmsConfig {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  propertyId     String    @unique
  type           String    @default("CLOUDBEDS")
  apiKey         String
  webhookSecret  String
  active         Boolean   @default(true)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("pms_configs")
}

model PropertySettings {
  id                  String    @id @default(uuid())
  organizationId      String?   @map("organization_id")
  propertyId          String    @unique
  defaultCheckoutTime String    @default("11:00")
  timezone            String    @default("America/Cancun")
  pmsMode             String    @default("STANDALONE")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("property_settings")
}

model BedDiscrepancy {
  id             String            @id @default(uuid())
  organizationId String?           @map("organization_id")
  bedId          String
  reportedById   String
  resolvedById   String?
  type           DiscrepancyType
  status         DiscrepancyStatus @default(OPEN)
  description    String
  resolution     String?
  createdById    String?           @map("created_by_id")
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?

  organization Organization?      @relation(fields: [organizationId], references: [id])
  bed          Bed                @relation(fields: [bedId], references: [id])
  reportedBy   HousekeepingStaff  @relation("DiscrepancyReporter", fields: [reportedById], references: [id])
  resolvedBy   HousekeepingStaff? @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])

  @@index([organizationId])
  @@index([bedId])
  @@index([status])
  @@map("bed_discrepancies")
}

// ======================= PMS CORE =======================

model RoomType {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  propertyId     String    @map("property_id")
  name           String
  code           String
  description    String?
  maxOccupancy   Int       @map("max_occupancy")
  baseRate       Decimal   @map("base_rate") @db.Decimal(10, 2)
  currency       String    @default("USD")
  amenities      String[]
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  rooms        Room[]

  @@unique([propertyId, code])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_types")
}

model RoomStatusLog {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")
  propertyId     String     @map("property_id")
  roomId         String     @map("room_id")
  fromStatus     RoomStatus @map("from_status")
  toStatus       RoomStatus @map("to_status")
  changedById    String     @map("changed_by_id")
  reason         String?
  createdAt      DateTime   @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  room         Room         @relation(fields: [roomId], references: [id])

  @@index([organizationId])
  @@index([roomId])
  @@index([createdAt])
  @@map("room_status_logs")
}

model GuestStay {
  id                String        @id @default(uuid())
  organizationId    String        @map("organization_id")
  propertyId        String        @map("property_id")
  roomId            String        @map("room_id")
  guestName         String        @map("guest_name")
  guestEmail        String?       @map("guest_email")
  guestPhone        String?       @map("guest_phone")
  documentType      String?       @map("document_type")
  documentNumber    String?       @map("document_number")
  nationality       String?
  paxCount          Int           @default(1) @map("pax_count")
  checkinAt         DateTime      @map("checkin_at")
  scheduledCheckout DateTime      @map("scheduled_checkout")
  actualCheckout    DateTime?     @map("actual_checkout")
  ratePerNight      Decimal       @map("rate_per_night") @db.Decimal(10, 2)
  currency          String        @default("USD")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  source            String?
  notes             String?
  checkedInById     String        @map("checked_in_by_id")
  checkedOutById    String?       @map("checked_out_by_id")
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  room         Room         @relation(fields: [roomId], references: [id])
  stayJourney  StayJourney?
  staySegments StaySegment[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([roomId])
  @@index([paymentStatus])
  @@map("guest_stays")
}

// ===================== PRE-CHECKIN QUALITY SYSTEM =====================
//
// Restaurado desde migration 20260402192948_add_pre_checkin_quality_system.
// Workflow: al hacer checkout de un huésped (OnEvent 'checkout.confirmed'),
// se crea automáticamente un RoomReadinessTask con items copiados del
// RoomTypeChecklist activo para la propiedad. Housekeeping los marca (PENDING
// → DONE | ISSUE_FOUND | SKIPPED) antes del siguiente check-in.

enum ReadinessStatus {
  PENDING
  IN_PROGRESS
  NEEDS_MAINTENANCE
  READY
  APPROVED
}

enum ItemStatus {
  PENDING
  DONE
  ISSUE_FOUND
  SKIPPED
}

model RoomTypeChecklist {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  roomTypeId     String?  @map("room_type_id")
  name           String
  triggerOn      String   @default("checkout")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization       @relation(fields: [organizationId], references: [id])
  items          ChecklistItem[]
  readinessTasks RoomReadinessTask[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_type_checklists")
}

model ChecklistItem {
  id            String   @id @default(uuid())
  checklistId   String   @map("checklist_id")
  category      String
  description   String
  isRequired    Boolean  @default(true) @map("is_required")
  requiresPhoto Boolean  @default(false) @map("requires_photo")
  sortOrder     Int      @default(0) @map("sort_order")

  checklist  RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  taskItems  RoomReadinessTaskItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model RoomReadinessTask {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  propertyId     String          @map("property_id")
  roomId         String          @map("room_id")
  checklistId    String          @map("checklist_id")
  assignedToId   String?         @map("assigned_to_id")
  triggeredBy    String          @map("triggered_by")
  status         ReadinessStatus @default(PENDING)
  dueBy          DateTime?       @map("due_by")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id])
  room         Room                    @relation(fields: [roomId], references: [id])
  checklist    RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  items        RoomReadinessTaskItem[]

  @@index([organizationId])
  @@index([roomId, status])
  @@map("room_readiness_tasks")
}

model RoomReadinessTaskItem {
  id                   String     @id @default(uuid())
  taskId               String     @map("task_id")
  checklistItemId      String     @map("checklist_item_id")
  status               ItemStatus @default(PENDING)
  completedById        String?    @map("completed_by_id")
  completedAt          DateTime?  @map("completed_at")
  photoUrl             String?    @map("photo_url")
  notes                String?
  maintenanceTicketId  String?    @map("maintenance_ticket_id")

  task          RoomReadinessTask @relation(fields: [taskId], references: [id])
  checklistItem ChecklistItem     @relation(fields: [checklistItemId], references: [id])

  @@index([taskId])
  @@map("room_readiness_task_items")
}

// ======================== STAY JOURNEY MODEL =========================
//
// Restaurado desde migration 20260410000000_add_stay_journey_model.
// Modela una estadía completa como journey + segmentos (permite extensiones
// y mudanzas de habitación) + nights (ingresos diarios para reporting).

enum StayJourneyStatus {
  ACTIVE
  CHECKED_OUT
  CANCELLED

  @@map("stay_journey_status")
}

enum SegmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("segment_status")
}

enum SegmentReason {
  ORIGINAL
  EXTENSION_SAME_ROOM
  EXTENSION_NEW_ROOM
  ROOM_MOVE

  @@map("segment_reason")
}

enum NightStatus {
  PENDING
  POSTED
  LOCKED

  @@map("night_status")
}

enum JourneyEventType {
  JOURNEY_CREATED
  SEGMENT_ADDED
  SEGMENT_LOCKED
  ROOM_MOVE_EXECUTED
  EXTENSION_APPROVED
  CHECKED_OUT
  CANCELLED

  @@map("journey_event_type")
}

model StayJourney {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  propertyId      String            @map("property_id")
  guestStayId     String?           @unique @map("guest_stay_id")
  guestName       String            @map("guest_name")
  guestEmail      String?           @map("guest_email")
  status          StayJourneyStatus @default(ACTIVE)
  journeyCheckIn  DateTime          @map("journey_check_in")
  journeyCheckOut DateTime          @map("journey_check_out")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  property     Property           @relation(fields: [propertyId], references: [id])
  guestStay    GuestStay?         @relation(fields: [guestStayId], references: [id])
  segments     StaySegment[]
  events       StayJourneyEvent[]

  @@index([organizationId, status])
  @@index([propertyId, journeyCheckIn, journeyCheckOut])
  @@map("stay_journeys")
}

model StaySegment {
  id           String        @id @default(uuid())
  journeyId    String        @map("journey_id")
  roomId       String        @map("room_id")
  guestStayId  String?       @map("guest_stay_id")
  checkIn      DateTime      @map("check_in")
  checkOut     DateTime      @map("check_out")
  status       SegmentStatus @default(PENDING)
  locked       Boolean       @default(false)
  reason       SegmentReason @default(ORIGINAL)
  rateSnapshot Decimal?      @map("rate_snapshot") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  journey   StayJourney    @relation(fields: [journeyId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  guestStay GuestStay?     @relation(fields: [guestStayId], references: [id])
  nights    SegmentNight[]

  @@index([journeyId])
  @@index([roomId, checkIn, checkOut])
  @@index([status, locked])
  @@map("stay_segments")
}

model SegmentNight {
  id        String      @id @default(uuid())
  segmentId String      @map("segment_id")
  date      DateTime    @db.Date
  rate      Decimal     @db.Decimal(10, 2)
  status    NightStatus @default(PENDING)
  locked    Boolean     @default(false)

  segment StaySegment @relation(fields: [segmentId], references: [id])

  @@unique([segmentId, date])
  @@index([date])
  @@index([segmentId, locked])
  @@map("segment_nights")
}

model StayJourneyEvent {
  id         String           @id @default(uuid())
  journeyId  String           @map("journey_id")
  eventType  JourneyEventType @map("event_type")
  actorId    String?          @map("actor_id")
  payload    Json
  occurredAt DateTime         @default(now()) @map("occurred_at")

  journey StayJourney @relation(fields: [journeyId], references: [id])

  @@index([journeyId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("stay_journey_events")
}
