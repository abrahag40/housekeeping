generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ======================= ENUMS =======================

enum AppNotificationType {
  INFORMATIONAL
  ACTION_REQUIRED
  APPROVAL_REQUIRED
}

enum AppNotificationCategory {
  CHECKIN_UNCONFIRMED
  EARLY_CHECKOUT
  NO_SHOW
  NO_SHOW_REVERTED
  ARRIVAL_RISK
  CHECKOUT_COMPLETE
  TASK_COMPLETED
  MAINTENANCE_REPORTED
  PAYMENT_PENDING
  SYSTEM
}

enum AppNotificationPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotificationRecipient {
  USER
  ROLE
  PROPERTY_ALL
}

enum ApprovalDecision {
  APPROVED
  REJECTED
  ESCALATED
}

enum UnitStatus {
  AVAILABLE
  OCCUPIED
  DIRTY
  CLEANING
  BLOCKED
}

enum CleaningStatus {
  PENDING
  READY
  UNASSIGNED
  IN_PROGRESS
  PAUSED
  DONE
  VERIFIED
  CANCELLED
}

enum HousekeepingRole {
  HOUSEKEEPER
  SUPERVISOR
  RECEPTIONIST
}

enum RoomCategory {
  PRIVATE
  SHARED
}

enum TaskType {
  CLEANING
  SANITIZATION
  MAINTENANCE
  PREPARATION
}

enum Capability {
  CLEANING
  SANITIZATION
  MAINTENANCE
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskLogEvent {
  CREATED
  ASSIGNED
  READY
  STARTED
  PAUSED
  RESUMED
  COMPLETED
  VERIFIED
  CANCELLED
  REOPENED
  NOTE_ADDED
}

enum CheckoutSource {
  MANUAL
  SYSTEM
}

enum MaintenanceCategory {
  PLUMBING
  ELECTRICAL
  FURNITURE
  PEST
  OTHER
}

enum DiscrepancyType {
  BED_STATUS_MISMATCH
  GUEST_EXTENSION
  UNEXPECTED_OCCUPANCY
  OTHER
}

enum DiscrepancyStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

// ── PMS Core enums ──

enum RoomStatus {
  AVAILABLE
  OCCUPIED
  CHECKING_OUT
  CLEANING
  INSPECTION
  MAINTENANCE
  OUT_OF_SERVICE
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  CREDIT
  OVERDUE
}

// ── New enums for multi-tenant foundation ──

enum OrgPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum SystemRole {
  OWNER
  MANAGER
  RECEPTIONIST
  HOUSEKEEPER
  TECHNICIAN
  AUDITOR
}

enum PropertyType {
  HOTEL
  HOSTAL
  BOUTIQUE
  GLAMPING
  ECO_LODGE
  VACATION_RENTAL
}

// ======================= MULTI-TENANT FOUNDATION =======================

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  plan        OrgPlan  @default(STARTER)
  countryCode String   @default("MX") @map("country_code")
  timezone    String   @default("America/Cancun")
  currency    String   @default("MXN")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Reverse relations (denormalized organizationId in all business tables)
  properties        Property[]
  users             User[]
  rooms             Room[]
  units             Unit[]
  housekeepingStaff HousekeepingStaff[]
  checkouts         Checkout[]
  cleaningTasks     CleaningTask[]
  taskLogs          TaskLog[]
  cleaningNotes     CleaningNote[]
  maintenanceIssues MaintenanceIssue[]
  unitDiscrepancies UnitDiscrepancy[]
  pushTokens        PushToken[]
  pmsConfigs        PmsConfig[]
  propertySettings  PropertySettings[]
  roomTypes         RoomType[]
  guestStays        GuestStay[]
  roomTypeChecklists RoomTypeChecklist[]
  roomReadinessTasks RoomReadinessTask[]
  stayJourneys       StayJourney[]
  roomBlocks         RoomBlock[]
  appNotifications   AppNotification[]

  @@map("organizations")
}

model User {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String    @map("first_name")
  lastName       String    @map("last_name")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization  Organization       @relation(fields: [organizationId], references: [id])
  propertyRoles UserPropertyRole[]
  staffProfiles HousekeepingStaff[]

  @@index([organizationId])
  @@map("users")
}

model UserPropertyRole {
  id         String     @id @default(uuid())
  userId     String     @map("user_id")
  propertyId String     @map("property_id")
  role       SystemRole
  createdAt  DateTime   @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id])
  property Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId, role])
  @@index([userId])
  @@index([propertyId])
  @@map("user_property_roles")
}

// ======================= CORE MODELS =======================

model Property {
  id             String        @id @default(uuid())
  organizationId String?       @map("organization_id")
  name           String
  type           PropertyType  @default(HOTEL)
  taxId          String?       @map("tax_id")
  // Optional geographic grouping for the property switcher.
  // `region` is the coarse grouping key (chains split by "Caribe",
  // "Pacífico", "Brasil", etc. — see Mews/Opera multi-property docs);
  // `city` disambiguates properties with the same name inside the
  // same region (Slack/Google-picker pattern).
  region         String?
  city           String?
  isActive       Boolean       @default(true) @map("is_active")
  deletedAt      DateTime?     @map("deleted_at")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  rooms        Room[]
  roomTypes    RoomType[]
  staff        HousekeepingStaff[]
  pmsConfig    PmsConfig?
  settings     PropertySettings?
  userRoles    UserPropertyRole[]
  stayJourneys StayJourney[]
  appNotifications AppNotification[]

  @@index([organizationId])
  @@map("properties")
}

model Room {
  id              String      @id @default(uuid())
  organizationId  String?     @map("organization_id")
  propertyId      String
  number          String
  floor           Int?
  category        RoomCategory
  capacity        Int
  status          RoomStatus  @default(AVAILABLE) @map("room_status")
  roomTypeId      String?     @map("room_type_id")
  channexRoomTypeId String?   @map("channex_room_type_id")   // ID del room type en Channex.io (Sprint 8)
  notes             String?
  deletedAt       DateTime?   @map("deleted_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  organization Organization?  @relation(fields: [organizationId], references: [id])
  property     Property       @relation(fields: [propertyId], references: [id])
  roomType     RoomType?       @relation(fields: [roomTypeId], references: [id])
  units        Unit[]
  checkouts    Checkout[]
  guestStays   GuestStay[]
  readinessTasks RoomReadinessTask[]
  staySegments StaySegment[]
  blocks       RoomBlock[]

  @@unique([propertyId, number])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([status])
  @@map("rooms")
}

model Unit {
  id             String     @id @default(uuid())
  organizationId String?    @map("organization_id")
  label          String
  roomId         String
  status         UnitStatus @default(AVAILABLE)
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt @map("updated_at")

  organization  Organization?     @relation(fields: [organizationId], references: [id])
  room          Room              @relation(fields: [roomId], references: [id])
  cleaningTasks CleaningTask[]
  discrepancies UnitDiscrepancy[]
  blocks        RoomBlock[]

  @@index([organizationId])
  @@map("units")
}

model HousekeepingStaff {
  id             String           @id @default(uuid())
  organizationId String?          @map("organization_id")
  userId         String?          @map("user_id")
  propertyId     String
  name           String
  email          String           @unique
  passwordHash   String
  role           HousekeepingRole
  active         Boolean          @default(true)
  capabilities   Capability[]
  deletedAt      DateTime?        @map("deleted_at")
  createdAt      DateTime         @default(now())

  organization  Organization?   @relation(fields: [organizationId], references: [id])
  user          User?           @relation(fields: [userId], references: [id])
  property      Property        @relation(fields: [propertyId], references: [id])
  tasks         CleaningTask[]  @relation("AssignedTasks")
  verifiedTasks CleaningTask[]  @relation("VerifiedTasks")
  taskLogs      TaskLog[]
  cleaningNotes          CleaningNote[]
  pushTokens             PushToken[]
  checkouts              Checkout[]        @relation("ManualCheckouts")
  issues                 MaintenanceIssue[]
  reportedDiscrepancies  UnitDiscrepancy[] @relation("DiscrepancyReporter")
  resolvedDiscrepancies  UnitDiscrepancy[] @relation("DiscrepancyResolver")
  requestedBlocks       RoomBlock[]      @relation("BlocksRequested")
  approvedBlocks        RoomBlock[]      @relation("BlocksApproved")
  blockLogs             BlockLog[]       @relation("BlockLogs")
  contactLogs           GuestContactLog[] @relation("ContactLogs")
  notificationsTriggered AppNotification[] @relation("NotifTriggeredBy")
  notificationReads      AppNotificationRead[] @relation("NotifReadBy")
  notificationApprovals  AppNotificationApproval[] @relation("NotifApprovedBy")
  collectedPayments      PaymentLog[]     @relation("PaymentCollectedBy")
  approvedPayments       PaymentLog[]     @relation("PaymentApprovedBy")
  voidedPayments         PaymentLog[]     @relation("PaymentVoidedBy")

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("housekeeping_staff")
}

model Checkout {
  id                     String         @id @default(uuid())
  organizationId         String?        @map("organization_id")
  roomId                 String
  guestName              String?
  actualCheckoutAt       DateTime
  source                 CheckoutSource
  isEarlyCheckout        Boolean        @default(false)
  hasSameDayCheckIn      Boolean        @default(false)
  notes                  String?
  enteredById            String?
  cancelled              Boolean        @default(false)
  cancelledAt            DateTime?
  createdAt              DateTime       @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  room         Room              @relation(fields: [roomId], references: [id])
  enteredBy    HousekeepingStaff? @relation("ManualCheckouts", fields: [enteredById], references: [id])
  tasks        CleaningTask[]

  @@index([organizationId])
  @@map("checkouts")
}

// TODO(hotel-room-granularity): CleaningTask fue diseñado hostel-first — unitId es NOT NULL
// y la tarea siempre se vincula a una unidad, nunca directamente a una habitación.
// Para hoteles con habitaciones dobles/twin (2 unidades, 1 unidad vendible), un bloqueo
// de habitación genera hoy N tareas MAINTENANCE (una por unidad) cuando debería ser 1.
// Refactor requerido:
//   1. Hacer unitId opcional: `unitId String?`
//   2. Añadir `roomId String?` (XOR con unitId — exactamente uno debe estar presente)
//   3. Actualizar TasksService, CleaningTaskDto, KanbanPage y mobile task/[id].tsx
//      para renderizar roomId cuando unitId sea null (tareas de bloqueo room-level)
//   4. Migración Prisma: no hay datos existentes de tipo MAINTENANCE, safe to migrate
model CleaningTask {
  id                 String         @id @default(uuid())
  organizationId     String?        @map("organization_id")
  unitId             String
  checkoutId         String?
  assignedToId       String?
  status             CleaningStatus @default(PENDING)
  taskType           TaskType       @default(CLEANING)
  // TODO(housekeeping-pms-bridge): agregar sourceType para distinguir el origen de la tarea.
  // Descomentar y migrar cuando se implemente el bridge PMS → Housekeeping (Sprint 7A/7B).
  // sourceType         CleaningTaskSource @default(CHECKOUT)
  // enum CleaningTaskSource { CHECKOUT, STAYOVER, ROOM_CHANGE, EXTENSION }
  requiredCapability Capability     @default(CLEANING)
  priority           Priority       @default(MEDIUM)
  hasSameDayCheckIn  Boolean        @default(false)
  startedAt          DateTime?
  finishedAt         DateTime?
  verifiedAt         DateTime?
  verifiedById       String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  organization Organization?      @relation(fields: [organizationId], references: [id])
  unit         Unit               @relation(fields: [unitId], references: [id])
  checkout     Checkout?          @relation(fields: [checkoutId], references: [id])
  assignedTo   HousekeepingStaff? @relation("AssignedTasks", fields: [assignedToId], references: [id])
  verifiedBy   HousekeepingStaff? @relation("VerifiedTasks", fields: [verifiedById], references: [id])
  logs         TaskLog[]
  notes        CleaningNote[]
  issues       MaintenanceIssue[]
  block        RoomBlock?         @relation("BlockTask")

  @@index([organizationId])
  @@index([status])
  @@index([assignedToId, status])
  @@index([unitId])
  @@index([checkoutId])
  @@map("cleaning_tasks")
}

model TaskLog {
  id             String       @id @default(uuid())
  organizationId String?      @map("organization_id")
  taskId         String
  staffId        String?
  event          TaskLogEvent
  note           String?
  createdAt      DateTime     @default(now())

  organization Organization?      @relation(fields: [organizationId], references: [id])
  task         CleaningTask       @relation(fields: [taskId], references: [id])
  staff        HousekeepingStaff? @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@index([taskId])
  @@map("task_logs")
}

model CleaningNote {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  taskId         String
  staffId        String
  content        String
  createdAt      DateTime @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  task         CleaningTask      @relation(fields: [taskId], references: [id])
  staff        HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("cleaning_notes")
}

model MaintenanceIssue {
  id             String              @id @default(uuid())
  organizationId String?             @map("organization_id")
  taskId         String
  reportedById   String
  category       MaintenanceCategory
  description    String
  photoUrl       String?
  resolved       Boolean             @default(false)
  createdAt      DateTime            @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  task         CleaningTask      @relation(fields: [taskId], references: [id])
  reportedBy   HousekeepingStaff @relation(fields: [reportedById], references: [id])

  @@index([organizationId])
  @@map("maintenance_issues")
}

model PushToken {
  id             String   @id @default(uuid())
  organizationId String?  @map("organization_id")
  staffId        String
  token          String   @unique
  platform       String
  active         Boolean  @default(true)
  lastSeenAt     DateTime @default(now())

  organization Organization?     @relation(fields: [organizationId], references: [id])
  staff        HousekeepingStaff @relation(fields: [staffId], references: [id])

  @@index([organizationId])
  @@map("push_tokens")
}

model PmsConfig {
  id             String    @id @default(uuid())
  organizationId String?   @map("organization_id")
  propertyId     String    @unique
  type           String    @default("CLOUDBEDS")
  apiKey         String
  webhookSecret  String
  active         Boolean   @default(true)
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("pms_configs")
}

model PropertySettings {
  id                  String    @id @default(uuid())
  organizationId      String?   @map("organization_id")
  propertyId          String    @unique
  defaultCheckoutTime String    @default("11:00")
  timezone            String    @default("America/Cancun")
  pmsMode             String    @default("STANDALONE")
  // Night audit: hora local a partir de la cual se procesan no-shows (0-23).
  // El scheduler corre cada 30 min y verifica hora local por propiedad.
  // Default 2 = 02:00 AM local — permite late arrivals por vuelos retrasados.
  noShowCutoffHour    Int       @default(2) @map("no_show_cutoff_hour")
  // Fecha (solo date, no datetime) del último procesamiento de no-shows.
  // El scheduler la compara con la fecha local actual para evitar doble ejecución.
  noShowProcessedDate DateTime? @db.Date @map("no_show_processed_date")
  // Pre-arrival warning cron: hora local (0-23) a partir de la cual el cron detecta
  // potenciales no-shows (huéspedes que debían llegar pero no lo hicieron aún).
  // Default 20 = 8 PM local. Si enableAutoOutreach es true, se envía WhatsApp/email.
  potentialNoShowWarningHour    Int       @default(20) @map("potential_no_show_warning_hour")
  potentialNoShowProcessedDate  DateTime? @db.Date @map("potential_no_show_processed_date")
  enableAutoOutreach            Boolean   @default(false) @map("enable_auto_outreach")
  // Channex.io channel manager (Sprint 8): ID de la propiedad en Channex para push de inventario.
  // Opcional — sin él, pushInventory() es no-op (fail-soft).
  channexPropertyId             String?   @map("channex_property_id")
  deletedAt           DateTime? @map("deleted_at")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id])
  property     Property      @relation(fields: [propertyId], references: [id])

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("property_settings")
}

model UnitDiscrepancy {
  id             String            @id @default(uuid())
  organizationId String?           @map("organization_id")
  unitId         String
  reportedById   String
  resolvedById   String?
  type           DiscrepancyType
  status         DiscrepancyStatus @default(OPEN)
  description    String
  resolution     String?
  createdAt      DateTime          @default(now())
  resolvedAt     DateTime?

  organization Organization?      @relation(fields: [organizationId], references: [id])
  unit         Unit               @relation(fields: [unitId], references: [id])
  reportedBy   HousekeepingStaff  @relation("DiscrepancyReporter", fields: [reportedById], references: [id])
  resolvedBy   HousekeepingStaff? @relation("DiscrepancyResolver", fields: [resolvedById], references: [id])

  @@index([organizationId])
  @@index([unitId])
  @@index([status])
  @@map("unit_discrepancies")
}

// ======================= PMS CORE =======================

model RoomType {
  id             String    @id @default(uuid())
  organizationId String    @map("organization_id")
  propertyId     String    @map("property_id")
  name           String
  code           String
  description    String?
  maxOccupancy   Int       @map("max_occupancy")
  baseRate       Decimal   @map("base_rate") @db.Decimal(10, 2)
  currency       String    @default("USD")
  amenities      String[]
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id])
  property     Property     @relation(fields: [propertyId], references: [id])
  rooms        Room[]

  @@unique([propertyId, code])
  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_types")
}

model GuestStay {
  id                String        @id @default(uuid())
  organizationId    String        @map("organization_id")
  propertyId        String        @map("property_id")
  roomId            String        @map("room_id")
  guestName         String        @map("guest_name")
  guestEmail        String?       @map("guest_email")
  guestPhone        String?       @map("guest_phone")
  documentType      String?       @map("document_type")
  documentNumber    String?       @map("document_number")
  nationality       String?
  paxCount          Int           @default(1) @map("pax_count")
  checkinAt         DateTime      @map("checkin_at")
  scheduledCheckout DateTime      @map("scheduled_checkout")
  actualCheckout       DateTime?     @map("actual_checkout")
  actualCheckin        DateTime?     @map("actual_checkin")
  checkinConfirmedById String?       @map("checkin_confirmed_by_id")
  ratePerNight      Decimal       @map("rate_per_night") @db.Decimal(10, 2)
  currency          String        @default("USD")
  totalAmount       Decimal       @map("total_amount") @db.Decimal(10, 2)
  amountPaid        Decimal       @default(0) @map("amount_paid") @db.Decimal(10, 2)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  source            String?
  notes             String?
  checkedInById     String        @map("checked_in_by_id")
  checkedOutById    String?       @map("checked_out_by_id")
  // ── No-show fields ───────────────────────────────────────────────────────
  // noShowAt != null indica que el huésped no se presentó y fue marcado.
  // La disponibilidad de la habitación excluye stays con noShowAt != null
  // (ver checkAvailability). El cargo se registra en noShowFeeAmount y su
  // estado en noShowChargeStatus (PENDING → CHARGED | FAILED | WAIVED).
  noShowAt           DateTime?           @map("no_show_at")
  noShowById         String?             @map("no_show_by_id")
  noShowReason       String?             @map("no_show_reason")
  noShowFeeAmount    Decimal?            @map("no_show_fee_amount") @db.Decimal(10, 2)
  noShowFeeCurrency  String?             @map("no_show_fee_currency")
  noShowChargeStatus NoShowChargeStatus? @map("no_show_charge_status")
  noShowRevertedAt   DateTime?           @map("no_show_reverted_at")
  noShowRevertedById String?             @map("no_show_reverted_by_id")
  // ── Check-in extended fields (Sprint 9) ─────────────────────────────────
  arrivalNotes  String?          @map("arrival_notes")
  keyType       KeyDeliveryType? @map("key_type")
  // ── Stripe card-on-file (Sprint 8) ───────────────────────────────────────
  // Guardados al hacer check-in via SetupIntent (usage: 'off_session').
  // stripePaymentIntentId se genera al procesar el cargo de no-show.
  stripeCustomerId      String?   @map("stripe_customer_id")
  stripePaymentMethodId String?   @map("stripe_payment_method_id")
  stripePaymentIntentId String?   @map("stripe_payment_intent_id")
  deletedAt         DateTime?     @map("deleted_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  // ── TODO(sprint8-pricing): campos para gestión de tarifas y channel manager ──
  // Descomentar y migrar cuando se implemente Sprint 8. Ver CLAUDE.md §Sprint 8.
  //
  // ratePlanId         String?    @map("rate_plan_id")         // FK → RatePlan
  // rateOverride       Decimal?   @map("rate_override") @db.Decimal(10, 2)
  // rateOverrideReason String?    @map("rate_override_reason")
  // channexRateId      String?    @map("channex_rate_id")      // ID en Channex.io
  // commissionRate     Decimal?   @map("commission_rate") @db.Decimal(5, 4)   // e.g. 0.15 = 15%
  //
  // TODO(sprint8-pricing): Nuevo modelo RatePlan (separado de GuestStay)
  // model RatePlan {
  //   id                String   @id @default(uuid())
  //   propertyId        String
  //   roomTypeId        String?
  //   name              String
  //   baseRate          Decimal  @db.Decimal(10, 2)
  //   currency          String   @default("MXN")
  //   channexRatePlanId String?
  //   isActive          Boolean  @default(true)
  //   markup            Decimal? @db.Decimal(5, 4)  // markup sobre tarifa base OTA
  //   createdAt         DateTime @default(now())
  //   updatedAt         DateTime @updatedAt
  // }

  organization Organization      @relation(fields: [organizationId], references: [id])
  room         Room              @relation(fields: [roomId], references: [id])
  stayJourney  StayJourney?
  staySegments StaySegment[]
  contactLogs  GuestContactLog[]
  paymentLogs  PaymentLog[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@index([roomId])
  @@index([paymentStatus])
  @@index([noShowAt])
  @@map("guest_stays")
}

// ===================== PRE-CHECKIN QUALITY SYSTEM =====================
//
// Restaurado desde migration 20260402192948_add_pre_checkin_quality_system.
// Workflow: al hacer checkout de un huésped (OnEvent 'checkout.confirmed'),
// se crea automáticamente un RoomReadinessTask con items copiados del
// RoomTypeChecklist activo para la propiedad. Housekeeping los marca (PENDING
// → DONE | ISSUE_FOUND | SKIPPED) antes del siguiente check-in.

enum ReadinessStatus {
  PENDING
  IN_PROGRESS
  NEEDS_MAINTENANCE
  READY
  APPROVED
}

enum ItemStatus {
  PENDING
  DONE
  ISSUE_FOUND
  SKIPPED
}

model RoomTypeChecklist {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  propertyId     String   @map("property_id")
  roomTypeId     String?  @map("room_type_id")
  name           String
  triggerOn      String   @default("checkout")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization   Organization       @relation(fields: [organizationId], references: [id])
  items          ChecklistItem[]
  readinessTasks RoomReadinessTask[]

  @@index([organizationId])
  @@index([organizationId, propertyId])
  @@map("room_type_checklists")
}

model ChecklistItem {
  id            String   @id @default(uuid())
  checklistId   String   @map("checklist_id")
  category      String
  description   String
  isRequired    Boolean  @default(true) @map("is_required")
  requiresPhoto Boolean  @default(false) @map("requires_photo")
  sortOrder     Int      @default(0) @map("sort_order")

  checklist  RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  taskItems  RoomReadinessTaskItem[]

  @@index([checklistId])
  @@map("checklist_items")
}

model RoomReadinessTask {
  id             String          @id @default(uuid())
  organizationId String          @map("organization_id")
  propertyId     String          @map("property_id")
  roomId         String          @map("room_id")
  checklistId    String          @map("checklist_id")
  assignedToId   String?         @map("assigned_to_id")
  triggeredBy    String          @map("triggered_by")
  status         ReadinessStatus @default(PENDING)
  dueBy          DateTime?       @map("due_by")
  approvedById   String?         @map("approved_by_id")
  approvedAt     DateTime?       @map("approved_at")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization            @relation(fields: [organizationId], references: [id])
  room         Room                    @relation(fields: [roomId], references: [id])
  checklist    RoomTypeChecklist       @relation(fields: [checklistId], references: [id])
  items        RoomReadinessTaskItem[]

  @@index([organizationId])
  @@index([roomId, status])
  @@map("room_readiness_tasks")
}

model RoomReadinessTaskItem {
  id                   String     @id @default(uuid())
  taskId               String     @map("task_id")
  checklistItemId      String     @map("checklist_item_id")
  status               ItemStatus @default(PENDING)
  completedById        String?    @map("completed_by_id")
  completedAt          DateTime?  @map("completed_at")
  photoUrl             String?    @map("photo_url")
  notes                String?
  maintenanceTicketId  String?    @map("maintenance_ticket_id")

  task          RoomReadinessTask @relation(fields: [taskId], references: [id])
  checklistItem ChecklistItem     @relation(fields: [checklistItemId], references: [id])

  @@index([taskId])
  @@map("room_readiness_task_items")
}

// ======================== STAY JOURNEY MODEL =========================
//
// Restaurado desde migration 20260410000000_add_stay_journey_model.
// Modela una estadía completa como journey + segmentos (permite extensiones
// y mudanzas de habitación) + nights (ingresos diarios para reporting).

enum StayJourneyStatus {
  ACTIVE
  CHECKED_OUT
  CANCELLED
  NO_SHOW

  @@map("stay_journey_status")
}

enum SegmentStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED

  @@map("segment_status")
}

enum SegmentReason {
  ORIGINAL
  EXTENSION_SAME_ROOM
  EXTENSION_NEW_ROOM
  ROOM_MOVE
  SPLIT

  @@map("segment_reason")
}

enum NightStatus {
  PENDING
  POSTED
  LOCKED

  @@map("night_status")
}

enum JourneyEventType {
  JOURNEY_CREATED
  SEGMENT_ADDED
  SEGMENT_LOCKED
  ROOM_MOVE_EXECUTED
  EXTENSION_APPROVED
  CHECKED_IN
  CHECKED_OUT
  CANCELLED
  NO_SHOW_MARKED
  NO_SHOW_REVERTED
  JOURNEY_SPLIT

  @@map("journey_event_type")
}

// ── Payment method for front-desk transactions ────────────────────────────────
// CARD_TERMINAL: POS físico externo — Zenix guarda solo el número de referencia
// del comprobante, nunca datos de tarjeta (PCI DSS fuera de alcance para TERMINAL).
enum PaymentMethod {
  CASH
  CARD_TERMINAL
  BANK_TRANSFER
  OTA_PREPAID
  COMP

  @@map("payment_method")
}

// ── Tipo de acceso físico entregado al huésped en check-in ────────────────────
enum KeyDeliveryType {
  PHYSICAL  // llave física tradicional
  CARD      // tarjeta magnética / RFID
  CODE      // PIN / código numérico
  MOBILE    // link o app móvil

  @@map("key_delivery_type")
}

// ── No-Show charge lifecycle ──────────────────────────────────────────────────
// NOT_APPLICABLE → policy = NONE (tarifa gratuita)
// PENDING        → registrado, esperando procesamiento de pago
// CHARGED        → cobro procesado exitosamente
// FAILED         → tarjeta rechazada (requiere acción manual)
// WAIVED         → exonerado por supervisor (fee perdonado)
enum NoShowChargeStatus {
  NOT_APPLICABLE
  PENDING
  CHARGED
  FAILED
  WAIVED
}

model StayJourney {
  id              String            @id @default(uuid())
  organizationId  String            @map("organization_id")
  propertyId      String            @map("property_id")
  guestStayId     String?           @unique @map("guest_stay_id")
  guestName       String            @map("guest_name")
  guestEmail      String?           @map("guest_email")
  status          StayJourneyStatus @default(ACTIVE)
  journeyCheckIn  DateTime          @map("journey_check_in")
  journeyCheckOut DateTime          @map("journey_check_out")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  organization Organization       @relation(fields: [organizationId], references: [id])
  property     Property           @relation(fields: [propertyId], references: [id])
  guestStay    GuestStay?         @relation(fields: [guestStayId], references: [id])
  segments     StaySegment[]
  events       StayJourneyEvent[]

  @@index([organizationId, status])
  @@index([propertyId, journeyCheckIn, journeyCheckOut])
  @@map("stay_journeys")
}

model StaySegment {
  id           String        @id @default(uuid())
  journeyId    String        @map("journey_id")
  roomId       String        @map("room_id")
  guestStayId  String?       @map("guest_stay_id")
  checkIn      DateTime      @map("check_in")
  checkOut     DateTime      @map("check_out")
  status       SegmentStatus @default(PENDING)
  locked       Boolean       @default(false)
  reason       SegmentReason @default(ORIGINAL)
  rateSnapshot Decimal?      @map("rate_snapshot") @db.Decimal(10, 2)
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  journey   StayJourney    @relation(fields: [journeyId], references: [id])
  room      Room           @relation(fields: [roomId], references: [id])
  guestStay GuestStay?     @relation(fields: [guestStayId], references: [id])
  nights    SegmentNight[]

  @@index([journeyId])
  @@index([roomId, checkIn, checkOut])
  @@index([status, locked])
  @@map("stay_segments")
}

model SegmentNight {
  id        String      @id @default(uuid())
  segmentId String      @map("segment_id")
  date      DateTime    @db.Date
  rate      Decimal     @db.Decimal(10, 2)
  status    NightStatus @default(PENDING)
  locked    Boolean     @default(false)

  segment StaySegment @relation(fields: [segmentId], references: [id])

  @@unique([segmentId, date])
  @@index([date])
  @@index([segmentId, locked])
  @@map("segment_nights")
}

model StayJourneyEvent {
  id         String           @id @default(uuid())
  journeyId  String           @map("journey_id")
  eventType  JourneyEventType @map("event_type")
  actorId    String?          @map("actor_id")
  payload    Json
  occurredAt DateTime         @default(now()) @map("occurred_at")

  journey StayJourney @relation(fields: [journeyId], references: [id])

  @@index([journeyId, occurredAt])
  @@index([eventType, occurredAt])
  @@map("stay_journey_events")
}

// ======================= SMARTBLOCK =======================

enum BlockSemantic {
  OUT_OF_SERVICE
  OUT_OF_ORDER
  OUT_OF_INVENTORY
  HOUSE_USE
}

enum BlockReason {
  MAINTENANCE
  DEEP_CLEANING
  INSPECTION
  PHOTOGRAPHY
  VIP_SETUP
  PEST_CONTROL
  WATER_DAMAGE
  ELECTRICAL
  PLUMBING
  STRUCTURAL
  RENOVATION
  OWNER_STAY
  STAFF_USE
  OTHER
}

enum BlockStatus {
  PENDING_APPROVAL
  APPROVED
  ACTIVE
  EXPIRED
  CANCELLED
  REJECTED
}

enum BlockLogEvent {
  CREATED
  APPROVED
  REJECTED
  ACTIVATED
  EXTENDED
  EARLY_RELEASE
  CANCELLED
  EXPIRED
  NOTE_ADDED
}

/**
 * RoomBlock — bloqueo de unidad o habitación con workflow de aprobación.
 *
 * Granularidad:
 *   unitId != null → bloqueo de unidad individual (dormitorios compartidos)
 *   unitId == null → bloqueo de habitación completa
 *
 * Semánticas:
 *   OUT_OF_SERVICE   → problema menor, no impacta RevPAR
 *   OUT_OF_ORDER     → inhabilitada, impacta RevPAR, requiere aprobación
 *   OUT_OF_INVENTORY → largo plazo, excluida del inventario operativo
 *   HOUSE_USE        → uso interno (fotos, staff)
 *
 * Al activarse (APPROVED → ACTIVE):
 *   1. Se crea CleaningTask(MAINTENANCE, UNASSIGNED)
 *   2. unit.status = BLOCKED
 *   3. SSE: block:activated
 *
 * Auto-aprobación:
 *   OOS + actor = SUPERVISOR → APPROVED inmediato (sin pasar por PENDING)
 *   HOUSE_USE + actor = SUPERVISOR → APPROVED inmediato
 *   Cualquier otro caso → PENDING_APPROVAL
 */
model RoomBlock {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  propertyId     String        @map("property_id")
  roomId         String?       @map("room_id")   // null = solo unidad
  unitId         String?       @map("unit_id")   // null = habitación completa

  semantic       BlockSemantic
  reason         BlockReason
  status         BlockStatus   @default(PENDING_APPROVAL)

  notes          String?                        // visible para housekeeping
  internalNotes  String?       @map("internal_notes") // solo supervisores

  startDate      DateTime      @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date")   @db.Date // null = indefinido

  requestedById  String        @map("requested_by_id")
  approvedById   String?       @map("approved_by_id")
  approvalNotes  String?       @map("approval_notes")
  approvedAt     DateTime?     @map("approved_at")

  // Tarea de mantenimiento creada automáticamente al activar el bloqueo
  cleaningTaskId String?       @unique @map("cleaning_task_id")

  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization      @relation(fields: [organizationId], references: [id])
  room           Room?             @relation(fields: [roomId], references: [id])
  unit           Unit?             @relation(fields: [unitId], references: [id])
  requestedBy    HousekeepingStaff @relation("BlocksRequested", fields: [requestedById], references: [id])
  approvedBy     HousekeepingStaff? @relation("BlocksApproved", fields: [approvedById], references: [id])
  cleaningTask   CleaningTask?     @relation("BlockTask", fields: [cleaningTaskId], references: [id])
  logs           BlockLog[]

  @@index([organizationId, propertyId, status])
  @@index([unitId, status])
  @@index([roomId, status])
  @@index([startDate, endDate])
  @@map("room_blocks")
}

/**
 * BlockLog — bitácora inmutable de cambios de estado.
 * staffId es null para eventos del sistema (cron, auto-activación).
 */
model BlockLog {
  id        String        @id @default(uuid())
  blockId   String        @map("block_id")
  staffId   String?       @map("staff_id")
  event     BlockLogEvent
  note      String?
  metadata  Json?         // contexto adicional: { previousStatus, reason, etc }
  createdAt DateTime      @default(now()) @map("created_at")

  block   RoomBlock          @relation(fields: [blockId], references: [id], onDelete: Cascade)
  staff   HousekeepingStaff? @relation("BlockLogs", fields: [staffId], references: [id], onDelete: SetNull)

  @@index([blockId])
  @@index([createdAt])
  @@map("block_logs")
}

// ── Guest contact channel ─────────────────────────────────────────────────────
enum ContactChannel {
  WHATSAPP
  EMAIL
  PHONE
}

// ── Guest contact log (append-only, for dispute documentation) ───────────────
// Cada intento de contacto queda registrado: quién lo hizo, cuándo, por qué canal.
// Usar como evidencia ante chargebacks u otras disputas con OTAs.
model GuestContactLog {
  id             String         @id @default(uuid())
  stayId         String         @map("stay_id")
  channel        ContactChannel
  // sentById es null para envíos automáticos del sistema (cron de potencial no-show).
  // Non-null para envíos manuales desde BookingDetailSheet (recepcionista identificado).
  sentById       String?        @map("sent_by_id")
  sentAt         DateTime       @default(now()) @map("sent_at")
  messagePreview String?        @map("message_preview")

  stay   GuestStay          @relation(fields: [stayId], references: [id])
  sentBy HousekeepingStaff? @relation("ContactLogs", fields: [sentById], references: [id])

  @@index([stayId])
  @@index([sentAt])
  @@map("guest_contact_logs")
}

// ======================= NOTIFICATION CENTER =======================
//
// Persistent, stored notifications with full audit trail (Facebook-style).
// Separate from NotificationsModule which provides ephemeral SSE streaming.
//
// Recipient targeting:
//   USER         → recipientId = staffId (personal notification)
//   ROLE         → recipientRole = HousekeepingRole (fan-out to role)
//   PROPERTY_ALL → all staff in the property
//
// Type lifecycle:
//   INFORMATIONAL    → read-only, no action needed
//   ACTION_REQUIRED  → surfaced prominently until read
//   APPROVAL_REQUIRED → records decision in AppNotificationApproval

model AppNotification {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  propertyId     String?                   @map("property_id")
  type           AppNotificationType
  category       AppNotificationCategory
  priority       AppNotificationPriority   @default(MEDIUM)
  title          String
  body           String
  metadata       Json?
  actionUrl      String?                   @map("action_url")
  recipientType  NotificationRecipient     @map("recipient_type")
  recipientId    String?                   @map("recipient_id")
  recipientRole  HousekeepingRole?         @map("recipient_role")
  triggeredById  String?                   @map("triggered_by_id")
  expiresAt      DateTime?                 @map("expires_at")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  organization   Organization              @relation(fields: [organizationId], references: [id])
  property       Property?                 @relation(fields: [propertyId], references: [id])
  triggeredBy    HousekeepingStaff?        @relation("NotifTriggeredBy", fields: [triggeredById], references: [id])
  reads          AppNotificationRead[]
  approvals      AppNotificationApproval[]

  @@index([organizationId, propertyId, createdAt(sort: Desc)])
  @@index([recipientId])
  @@index([recipientRole])
  @@map("app_notifications")
}

model AppNotificationRead {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  readById       String              @map("read_by_id")
  readAt         DateTime            @default(now()) @map("read_at")

  notification   AppNotification     @relation(fields: [notificationId], references: [id])
  readBy         HousekeepingStaff   @relation("NotifReadBy", fields: [readById], references: [id])

  @@unique([notificationId, readById])
  @@map("app_notification_reads")
}

model AppNotificationApproval {
  id             String              @id @default(uuid())
  notificationId String              @map("notification_id")
  action         ApprovalDecision
  actionById     String              @map("action_by_id")
  actionAt       DateTime            @default(now()) @map("action_at")
  reason         String?

  notification   AppNotification     @relation(fields: [notificationId], references: [id])
  actionBy       HousekeepingStaff   @relation("NotifApprovedBy", fields: [actionById], references: [id])

  @@map("app_notification_approvals")
}

// ======================= PAYMENT LOG =======================
//
// Registro inmutable de pagos recibidos en recepción (USALI-compliant).
// Reglas de inmutabilidad:
//   - No hay campo updatedAt — Prisma no genera rutas UPDATE para este modelo.
//   - La capa de servicio solo permite create(). Nunca update().
//   - Las anulaciones crean un nuevo registro con isVoid=true y amount negativo.
//   - El registro original permanece intacto (trail auditnable).
//
// Anti-fraude:
//   - collectedById identifica al recepcionista que cobró.
//   - COMP / amount=0 requieren approvedById + approvalReason obligatorios.
//   - shiftDate permite reconciliar por turno: sum(CASH, isVoid=false) vs. efectivo físico.
//   - reference = número de autorización del terminal (6-8 dígitos del comprobante),
//     nunca PAN / CVV / track data. Zenix está fuera del flujo de datos de tarjeta.

model PaymentLog {
  id             String        @id @default(uuid())
  organizationId String        @map("organization_id")
  propertyId     String        @map("property_id")
  stayId         String        @map("stay_id")
  method         PaymentMethod
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("MXN")
  reference      String?                           // autorización terminal / referencia bancaria
  approvedById   String?       @map("approved_by_id")
  approvalReason String?       @map("approval_reason")
  isVoid         Boolean       @default(false) @map("is_void")
  voidedAt       DateTime?     @map("voided_at")
  voidedById     String?       @map("voided_by_id")
  voidReason     String?       @map("void_reason")
  voidsLogId     String?       @unique @map("voids_log_id")
  shiftDate      DateTime      @db.Date @map("shift_date")
  collectedById  String        @map("collected_by_id")
  createdAt      DateTime      @default(now()) @map("created_at")

  stay         GuestStay            @relation(fields: [stayId], references: [id])
  collectedBy  HousekeepingStaff    @relation("PaymentCollectedBy", fields: [collectedById], references: [id])
  approvedBy   HousekeepingStaff?   @relation("PaymentApprovedBy", fields: [approvedById], references: [id])
  voidedBy     HousekeepingStaff?   @relation("PaymentVoidedBy", fields: [voidedById], references: [id])
  voidsEntry   PaymentLog?          @relation("VoidOf", fields: [voidsLogId], references: [id])
  voidedByLog  PaymentLog?          @relation("VoidOf")

  @@index([stayId])
  @@index([organizationId, propertyId, shiftDate])
  @@index([collectedById, shiftDate])
  @@map("payment_logs")
}
